{
    "data_path": "../Data/orsm_matrix.csv",
    "locations_path": "../Data/locations.csv",
    "output_dir": "result",
    "visualization": {
        "osrm_url": "http://localhost:5001",
        "map_filename": "route_map.html",
        "zoom_start": 13
